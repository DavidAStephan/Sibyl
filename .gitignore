/.quarto/
*_files/
*_cache/
/site_libs/

# Built docs and reports
/docs/
reports/_book/
reports/*.html
reports/*.pdf
reports/*_files/

# Parquet / data caches
data/cache/**/*.parquet
data/cache/**/*.feather
data/cache/**/*.csv
data/cache/**/*.rds
!data/cache/.gitkeep

# Capture-script output
scripts/output/

# Package build artefacts
packages/*/inst/doc/
