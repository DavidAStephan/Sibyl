.Rapp.history
*.Rproj
.Rcheck/

# Environment / secrets
.Renviron
.env

# renv — keep lockfile, ignore the library
renv/library/
renv/python/
renv/staging/
renv/local/
renv/lock-restored

# targets pipeline state
_targets/
_targets_r/

